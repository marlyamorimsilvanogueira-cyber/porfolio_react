{
  "include": [
    "client/src/**/*",
    "shared/**/*",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",

    "moduleResolution": "bundler",

    "lib": ["ESNext", "DOM", "DOM.Iterable"],

    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,

    "incremental": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo",

    "esModuleInterop": true,
    "skipLibCheck": true,

    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    "baseUrl": ".",

    "types": ["vite/client"],

    "paths": {
      "@/*": ["client/src/*"],
      "@shared/*": ["shared/*"]
    }
  }
}